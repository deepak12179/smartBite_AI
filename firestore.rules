rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Hardened Global Helpers ---
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function isSignedIn() { 
      return request.auth != null; 
    }
    
    function isOwner(userId) { 
      return isSignedIn() && request.auth.uid == userId; 
    }
    
    function isMockUser(userId) {
      return userId is string && (userId.matches('mock_google_.*') || userId.matches('^mock_google_.*'));
    }
    
    function incoming() { 
      return request.resource.data; 
    }
    
    function existing() { 
      return resource.data; 
    }

    // --- Standalone Entity Validation Helpers ---
    
    function isValidUserProfile(data, userId) {
      return data.keys().hasAll([
        'uid', 'displayName', 'email', 'age', 'weight', 'height', 
        'dailyCalorieGoal', 'healthGoals', 'dietPlan', 'streakCount', 
        'lastLoggedDate', 'points', 'badges'
      ])
      && data.keys().size() >= 13 && data.keys().size() <= 20
      && data.uid is string && isValidId(data.uid) && data.uid == userId
      && data.displayName is string && data.displayName.size() >= 1 && data.displayName.size() <= 250
      && data.email is string && data.email.size() >= 3 && data.email.size() <= 250
      && (data.age is int || data.age is float) && data.age >= 0.0 && data.age <= 150.0
      && (data.weight is int || data.weight is float) && data.weight > 0.0 && data.weight <= 1000.0
      && (data.height is int || data.height is float) && data.height > 0.0 && data.height <= 500.0
      && (data.dailyCalorieGoal is int || data.dailyCalorieGoal is float) && data.dailyCalorieGoal >= 100.0 && data.dailyCalorieGoal <= 50000.0
      && data.healthGoals is string && data.healthGoals in ["Lose weight", "Build muscle", "Stay healthy", "Increase athletic performance"]
      && data.dietPlan is string && data.dietPlan in ["Balanced", "Keto", "Low Carb", "High Protein", "Vegetarian"]
      && (data.streakCount is int || data.streakCount is float) && data.streakCount >= 0.0
      && (!('lastLoggedDate' in data) || data.lastLoggedDate == null || (data.lastLoggedDate is string && data.lastLoggedDate.size() <= 50))
      && (data.points is int || data.points is float) && data.points >= 0.0
      && data.badges is list && data.badges.size() <= 200
      && (!('gender' in data) || data.gender == null || (data.gender is string && data.gender in ['Male', 'Female']))
      && (!('activityLevel' in data) || data.activityLevel == null || (data.activityLevel is string && data.activityLevel in ['Sedentary', 'Light', 'Moderate', 'Active']))
      && (!('targetWeight' in data) || data.targetWeight == null || ((data.targetWeight is int || data.targetWeight is float) && data.targetWeight >= 0.0 && data.targetWeight <= 1000.0));
    }

    function isValidFoodLog(data, userId) {
      return data.keys().hasAll([
        'id', 'userId', 'timestamp', 'date', 'foodName', 'mealType', 
        'calories', 'protein', 'carbs', 'fats', 'vitamins', 'minerals', 
        'healthScore', 'summary', 'recommendation', 'reason'
      ])
      && data.keys().size() >= 16 && data.keys().size() <= 22
      && data.id is string && isValidId(data.id)
      && data.userId is string && data.userId == userId
      && data.timestamp is string && data.timestamp.size() <= 100
      && data.date is string && data.date.size() <= 50
      && data.foodName is string && data.foodName.size() >= 1 && data.foodName.size() <= 500
      && data.mealType is string && data.mealType in ['Breakfast', 'Lunch', 'Dinner', 'Snack']
      && (data.calories is int || data.calories is float) && data.calories >= 0.0 && data.calories <= 25000.0
      && (data.protein is int || data.protein is float) && data.protein >= 0.0 && data.protein <= 5000.0
      && (data.carbs is int || data.carbs is float) && data.carbs >= 0.0 && data.carbs <= 5000.0
      && (data.fats is int || data.fats is float) && data.fats >= 0.0 && data.fats <= 5000.0
      && data.vitamins is list && data.vitamins.size() <= 100
      && data.minerals is list && data.minerals.size() <= 100
      && (data.healthScore is int || data.healthScore is float) && data.healthScore >= 0.0 && data.healthScore <= 100.0
      && data.summary is string && data.summary.size() <= 5000
      && data.recommendation is string && data.recommendation in ['EAT', 'MODERATE', 'AVOID']
      && data.reason is string && data.reason.size() <= 5000
      && (!('imageBase64' in data) || data.imageBase64 == null || (data.imageBase64 is string && data.imageBase64.size() <= 2000000))
      && (!('dietaryFiber' in data) || data.dietaryFiber == null || (data.dietaryFiber is int || data.dietaryFiber is float));
    }

    function isValidChallenge(data) {
      return data.keys().hasAll([
        'id', 'title', 'description', 'durationDays', 'pointsValue', 
        'progress', 'completed', 'type', 'icon'
      ])
      && data.keys().size() >= 9 && data.keys().size() <= 12
      && data.id is string && isValidId(data.id)
      && data.title is string && data.title.size() <= 300
      && data.description is string && data.description.size() <= 2000
      && (data.durationDays is int || data.durationDays is float) && data.durationDays >= 0.0
      && (data.pointsValue is int || data.pointsValue is float) && data.pointsValue >= 0.0
      && (data.progress is int || data.progress is float) && data.progress >= 0.0
      && data.completed is bool
      && data.type is string && data.type in ['streak', 'protein', 'calories', 'clean-eating']
      && data.icon is string && data.icon.size() <= 100;
    }

    function isValidInAppNotification(data) {
      return data.keys().hasAll([
        'id', 'title', 'message', 'timestamp', 'read', 'type'
      ])
      && data.keys().size() >= 6 && data.keys().size() <= 10
      && data.id is string && isValidId(data.id)
      && data.title is string && data.title.size() <= 500
      && data.message is string && data.message.size() <= 5000
      && data.timestamp is string && data.timestamp.size() <= 100
      && data.read is bool
      && data.type is string && data.type in ['goal', 'reminder', 'streak', 'badge'];
    }

    // --- Master Collection Match Blocks ---
    match /test/{documentId} {
      allow read: if true;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isMockUser(userId);
      allow create: if (isOwner(userId) || isMockUser(userId)) && isValidUserProfile(incoming(), userId);
      allow update: if (isOwner(userId) || isMockUser(userId)) && isValidUserProfile(incoming(), userId) && (
        incoming().uid == existing().uid &&
        incoming().email == existing().email
      );
      allow delete: if isOwner(userId) || isMockUser(userId);

      match /foodLogs/{logId} {
        allow get, list: if isOwner(userId) || isMockUser(userId);
        allow create: if (isOwner(userId) || isMockUser(userId)) && isValidFoodLog(incoming(), userId) && isValidId(logId);
        allow update: if (isOwner(userId) || isMockUser(userId)) && isValidFoodLog(incoming(), userId) && isValidId(logId) && (
          incoming().id == existing().id &&
          incoming().userId == existing().userId
        );
        allow delete: if isOwner(userId) || isMockUser(userId);
      }

      match /challenges/{challengeId} {
        allow get, list: if isOwner(userId) || isMockUser(userId);
        allow create: if (isOwner(userId) || isMockUser(userId)) && isValidChallenge(incoming()) && isValidId(challengeId);
        allow update: if (isOwner(userId) || isMockUser(userId)) && isValidChallenge(incoming()) && isValidId(challengeId) && (
          incoming().id == existing().id
        );
        allow delete: if isOwner(userId) || isMockUser(userId);
      }

      match /notifications/{notificationId} {
        allow get, list: if isOwner(userId) || isMockUser(userId);
        allow create: if (isOwner(userId) || isMockUser(userId)) && isValidInAppNotification(incoming()) && isValidId(notificationId);
        allow update: if (isOwner(userId) || isMockUser(userId)) && isValidInAppNotification(incoming()) && isValidId(notificationId) && (
          incoming().id == existing().id
        );
        allow delete: if isOwner(userId) || isMockUser(userId);
      }
    }
  }
}
